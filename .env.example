# skas-algo-platform configuration — copy to .env and fill in.
# .env is git-ignored. NEVER commit real secrets.

# --- App ---
SKAS_ENVIRONMENT=development
SKAS_DEBUG=true
SKAS_LOG_LEVEL=INFO

# --- Database (platform state) ---
# Local dev default is SQLite; use Postgres on the VPS:
# SKAS_DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/skas_algo
SKAS_DATABASE_URL=sqlite:///./skas_algo.db

# --- API server ---
# Localhost only by default (single-user, real money). Use 0.0.0.0 ONLY inside a container
# or behind a proxy/private network — never expose it raw on a LAN/public interface.
SKAS_API_HOST=127.0.0.1
SKAS_API_PORT=8080
# JSON array of allowed origins for the web UI
SKAS_CORS_ORIGINS=["http://localhost:5173"]
# Serve the built React SPA (web/dist) from the backend, single-origin (prod, e.g. the VPS).
# Leave false for local dev (the Vite dev server on :5173 hosts the UI). Set true after
# `npm run build`. SKAS_WEBAPP_DIST overrides the path (default: the repo's web/dist).
SKAS_SERVE_WEBAPP=false
# SKAS_WEBAPP_DIST=/absolute/path/to/web/dist

# --- Encryption for broker creds / TOTP at rest (REQUIRED to connect a broker) ---
# Generate: python -c "from skas_algo.security import generate_key; print(generate_key())"
SKAS_SECRET_ENCRYPTION_KEY=

# --- App authentication (single operator password → JWT bearer) ---
# FAIL-OPEN: leave BOTH blank on localhost and the API is open (no login). On any networked
# host (the VPS) set BOTH, or the API is unauthenticated.
#   hash:   venv/bin/skas-algo hash-password
#   secret: python -c "import secrets; print(secrets.token_urlsafe(48))"
SKAS_AUTH_PASSWORD_HASH=
SKAS_AUTH_JWT_SECRET=
# SKAS_AUTH_TOKEN_TTL_HOURS=24

# --- Backups ---
# On-box VACUUM-INTO snapshots to backups/ (last SKAS_DB_BACKUP_KEEP, default 7) run at
# startup + nightly ~16:30 IST. For OFF-box durability (disk failure), set a command the
# nightly backup runs on the fresh snapshot; {path}=abs path, {name}=filename. e.g.:
#   SKAS_BACKUP_REMOTE_CMD=rsync -az {path} user@backup-host:/skas-backups/
# SKAS_DB_BACKUP_KEEP=7
SKAS_BACKUP_REMOTE_CMD=

# --- Alerts (Telegram) ---
# Create a bot via @BotFather for the token; get your chat id from @userinfobot.
SKAS_TELEGRAM_BOT_TOKEN=
SKAS_TELEGRAM_CHAT_ID=

# --- Live trading safety switch ---
# Master kill-switch. No real order is placed unless this is true AND the account is
# armed. Keep false for paper/forward-test.
SKAS_LIVE_TRADING_ENABLED=false

# --- Broker credentials (Zerodha) ---
# Not set here. Connect an account in the UI (Brokers tab): label, user_id, api_key,
# api_secret. The api_secret is stored encrypted in the DB. You log in to Kite
# yourself and paste the request_token; it's exchanged for the daily access token.
