# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/

# Test / coverage
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# Secrets & local config (never commit broker creds / TOTP / tokens)
.env
.env.*
!.env.example
*.key
*.pem
access_token.txt
.kite_session_*.json
secrets/

# Databases / data
*.db
*.db-wal
*.db-shm
*.duckdb
*.sqlite
*.sqlite3
# On-box rolling DB snapshots (services/backup.py) — live state, never commit.
/backups/
# Root-anchored so these only ignore the local cache/output dirs at the repo root —
# NOT the src/skas_algo/data Python package (which must be tracked).
/data/
/exports/

# Node / frontend
node_modules/
web/dist/
web/.vite/

# OS / editor
.DS_Store
.idea/
.vscode/
*.log

# launchd supervisor logs
/logs/

# mobile app (web-mobile workspace + iOS shell build artifacts)
web-mobile/dist/
web-mobile/ios/App/App/public/
web-mobile/ios/DerivedData/
